rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow unauthenticated reads for the offices collection so they can see locations on signup.
    // Writes are restricted to authenticated users.
    match /offices/{officeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow unauthenticated reads, updates, and creations for the users collection
    // (needed for forgot-password resets, hybrid login fallback check, and signup)
    match /users/{userId} {
      allow read, update, create: if true;
      allow delete: if request.auth != null;
    }

    // Default rule: Require authentication for all other collections and documents
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
